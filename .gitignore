#do not push settings files
/configurations/ossn.config.db.php
/configurations/ossn.config.site.php

#do not include following files
/components/*
/cache
/installation/INSTALLED
/.htaccess
Thumbs.db
Desktop.ini
DISPLAY_ERRORS
error_log

#do not ignore ossn core components
!/components/OssnAds
!/components/OssnBlock
!/components/OssnComments
!/components/OssnEmbed
!/components/OssnGroups
!/components/OssnInvite
!/components/OssnLikes
!/components/OssnMessages
!/components/OssnNotifications
!/components/OssnPhotos
!/components/OssnPoke
!/components/OssnProfile
!/components/OssnSearch
!/components/OssnSitePages
!/components/OssnSmilies
!/components/OssnWall
!/components/OssnChat
!/components/OssnSounds
!/components/OssnAutoPagination
!/components/OssnMessageTyping
!/components/OssnRealTimeComments
!/components/OssnPostBackground
!/components/OssnGiphy
!/components/OssnLocation

#do not ignore config files
!/.scrutinizer.yml
!/.travis.yml
!.gitignore

# ── TribeConnect custom components (always include) ───────────────────
!/components/TribeConnectPremium
!/components/TribeConnectAds
!/components/TribeConnectAnalytics
!/components/TribeConnectVerification
!/components/TribeConnectCreatorSubs

# (TribeConnect theme, docs, and preview are tracked — no ignore rules needed)

# ── Web3 App — exclude build artefacts & secrets only ────────────────
web3-app/node_modules/
web3-app/.next/
web3-app/out/
web3-app/web3/artifacts/
web3-app/web3/cache/
web3-app/.env.local
web3-app/*.log

# Installation SQL
installation/sql/tribeconnect.sql
