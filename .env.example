# ═══════════════════════════════════════════════════════════════
# TribeConnect — Environment Variables
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Xaman (XUMM) API — GET AT https://apps.xumm.dev ──────────
# Server-side only — NEVER expose to browser
XUMM_API_KEY=your_xumm_api_key_here
XUMM_API_SECRET=your_xumm_api_secret_here

# Public key for client (safe to expose)
NEXT_PUBLIC_XUMM_API_KEY=your_xumm_api_key_here

# ── JWT Session ───────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_64_chars

# ── XRPL Network ─────────────────────────────────────────────
# "mainnet" | "testnet" | "devnet"
NEXT_PUBLIC_XRPL_NETWORK=testnet

NEXT_PUBLIC_XRPL_WS_MAINNET=wss://xrplcluster.com
NEXT_PUBLIC_XRPL_WS_TESTNET=wss://s.altnet.rippletest.net:51233
NEXT_PUBLIC_XRPL_WS_DEVNET=wss://s.devnet.rippletest.net:51233

# XRPL explorer base URL
NEXT_PUBLIC_XRPL_EXPLORER=https://testnet.xrpl.org

# Platform treasury wallet (receives premium fees)
PLATFORM_XRPL_ADDRESS=rYourPlatformWalletAddressHere
PLATFORM_XRPL_SECRET=sYourPlatformWalletSecretHere_NEVER_COMMIT

# ── XRPL EVM Smart Contract Addresses ────────────────────────
# Set after running: npm run deploy:devnet / npm run deploy:testnet
NEXT_PUBLIC_CONTRACT_DEVNET=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CONTRACT_TESTNET=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CONTRACT_MAINNET=0x0000000000000000000000000000000000000000

# ── WalletConnect ─────────────────────────────────────────────
# GET AT https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ── Pinata IPFS — GET AT https://pinata.cloud ─────────────────
NEXT_PUBLIC_PINATA_API_KEY=your_pinata_api_key
NEXT_PUBLIC_PINATA_SECRET_KEY=your_pinata_secret_key
NEXT_PUBLIC_PINATA_JWT=your_pinata_jwt
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TribeConnect

# XRP Premium Prices (in drops: 1 XRP = 1,000,000 drops)
# 5 XRP/month Pro, 12 XRP/month Creator
NEXT_PUBLIC_PRO_PRICE_DROPS=5000000
NEXT_PUBLIC_CREATOR_PRICE_DROPS=12000000
